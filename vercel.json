{
  "version": 2,
  "buildCommand": "npm --prefix frontend run build && pip install -r backend/requirements.txt",
  "outputDirectory": "frontend/dist",
  "functions": {
    "backend/app/main.py": {
      "runtime": "python3.11",
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/app/main.py"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/dist/index.html"
    }
  ]
}
